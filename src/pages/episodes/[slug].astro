---
import { getCollection } from 'astro:content';
import MarkdownEpisodeLayout from '../../layouts/MarkdownEpisodeLayout.astro';

export async function getStaticPaths() {
  const episodes = await getCollection('episodes', ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });
  episodes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  const episodeCount = episodes.length;

  return episodes.map((entry, index) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      nextepisode: index + 1 !== episodeCount ? episodes[index + 1] : null,
      prevepisode: index !== 0 ? episodes[index - 1] : null,
    },
  }));
}

const { entry, prevepisode, nextepisode } = Astro.props;
const { Content } = await entry.render();
---

<MarkdownEpisodeLayout
  frontmatter={entry.data}
  slug={entry.slug}
  prevepisode={prevepisode}
  nextepisode={nextepisode}
>
  <Content />
</MarkdownEpisodeLayout>
