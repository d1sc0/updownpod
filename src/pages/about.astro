---
import MarkdownPageLayout from '../layouts/MarkdownPageLayout.astro';
import { getEntry, render } from 'astro:content';

const about = await getEntry('pages', 'about');
const { Content } = about ? await render(about) : { Content: null };
const pageMeta = {
  title: about?.data.title || 'Upstairs Downstairs Podcast | About the show',
  description:
    about?.data.description || 'A little bit of background about the show',
  imageUrl: '/podcast-default-social.png',
};
---

<MarkdownPageLayout frontmatter={about?.data} pageMeta={pageMeta}>
  {Content && <Content />}
</MarkdownPageLayout>
