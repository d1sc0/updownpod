---
import { getCollection } from 'astro:content';
import '../styles/latest-episode.css';
import { Icon } from 'astro-icon/components';
import subscribeLinks from '../content/subscribe-links.json';

const allEpisodes = await getCollection('episodes', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});
const latestEpisode = allEpisodes.reduce(
  (latest, ep) =>
    new Date(ep.data.pubDate) > new Date(latest.data.pubDate) ? ep : latest,
  allEpisodes[0],
);

if (!latestEpisode) {
  // Handle case where no episodes exist
  console.warn('No episodes found');
}

const dateOptions: object = {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
};
const formattedPublishDate = new Date(
  latestEpisode.data.pubDate,
).toLocaleDateString('en-UK', dateOptions);
// Generate a unique ID for this component instance
const uniqueId = `audio-player-${Math.random().toString(36).substr(2, 9)}`;
---

{
  latestEpisode && (
    <section class="latest-episode-player">
      <div class="audio-player-section">
        <div class="custom-audio-player" data-player-id={uniqueId}>
          <audio id={`audio-element-${uniqueId}`} preload="metadata">
            <source src={latestEpisode.data.mp3} type="audio/mpeg" />
            Your browser does not support the audio element.
          </audio>
          <div class="player-content-grid">
            <div class="episode-image-placeholder">
              <img
                src={`/generated_preview_images/${latestEpisode.id || latestEpisode.data.slug}.png`}
                alt="Episode cover"
                width={400}
                height={400}
                class="episode-image"
              />
            </div>
            <div class="audio-info">
              <h3>{latestEpisode.data.title}</h3>
              <p class="episode-date">{formattedPublishDate}</p>
              <p class="episode-excerpt">{latestEpisode.data.description}</p>
              <p>
                <a href={`/episodes/${latestEpisode.data.slug}`}>
                  read show notes...
                </a>
              </p>
            </div>
          </div>
          <div class="audio-controls">
            <button
              id={`play-pause-btn-${uniqueId}`}
              class="play-btn"
              aria-label="Play"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path d="M8 5v14l11-7z" fill="currentColor" />
              </svg>
            </button>
            <div class="progress-time-container">
              <div class="progress-container">
                <div class="progress-bar">
                  <div class="progress-fill" id={`progress-fill-${uniqueId}`} />
                </div>
                <input
                  type="range"
                  id={`progress-slider-${uniqueId}`}
                  class="progress-slider"
                  min="0"
                  max="100"
                  value="0"
                  step="0.1"
                />
              </div>
              <div class="time-display">
                <span id={`current-time-${uniqueId}`}>0:00</span> /{' '}
                <span id={`duration-${uniqueId}`}>0:00</span>
              </div>
            </div>
            <div class="volume-container">
              <button
                id={`volume-btn-${uniqueId}`}
                class="volume-btn"
                aria-label="Volume"
              >
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"
                    fill="currentColor"
                  />
                </svg>
              </button>
              <input
                type="range"
                id={`volume-slider-${uniqueId}`}
                class="volume-slider"
                min="0"
                max="1"
                value="1"
                step="0.01"
              />
            </div>
          </div>
        </div>
      </div>
    </section>
    <section class="subscribe-links">
        <ul class="subscribe-platforms">
          {subscribeLinks.links.map(link => (
            <li>
              <a href={link.url} target="_blank" rel="noopener">
                <Icon name={link.icon} size="35" />
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </section>
  )
}
