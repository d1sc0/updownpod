---
import { AstroFont } from 'astro-font';
---

<AstroFont
  config={[
    {
      src: [],
      name: 'Manrope',
      // Google Fonts URL
      googleFontsURL:
        'https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap',
      preload: true,
      display: 'swap',
      selector: 'body',
      fallback: 'sans-serif',
    },
  ]}
/>
<AstroFont
  config={[
    {
      src: [],
      name: 'Jersey15',
      // Google Fonts URL
      googleFontsURL:
        'https://fonts.googleapis.com/css2?family=Jersey+15&display=swap',
      preload: true,
      display: 'swap',
      cssVariable: 'Jersey15',
      fallback: 'sans-serif',
    },
  ]}
/>
