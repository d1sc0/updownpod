---
const { episodes, gridTitle } = Astro.props;
import EpisodePreview from './EpisodePreview.astro';
---

<section class="episodegrid">
  <h2 class="content-padding">{gridTitle}</h2>
  <div class="grid content-padding">
    {episodes.map(episode => <EpisodePreview data={episode.data} />)}
  </div>
</section>
