---
import { SEO } from 'astro-seo';
const { frontmatter, pageMeta } = Astro.props;
import Fonts from '../components/Fonts.astro';

const siteURL = 'https://updownpod.com';

// Determine the slug/id for the OG image (prefer id, fallback to slug, fallback to url path)
const urlPath = Astro.url?.pathname?.replace(/\/$/, '') || '';
const urlId =
  frontmatter?.id || frontmatter?.slug || urlPath.split('/').pop() || 'index';
const ogImage = `${siteURL}/generated_preview_images/${urlId}.png`;

const title =
  pageMeta?.title ||
  (frontmatter?.title
    ? `Upstairs Downstairs Podcast | ${frontmatter.title}`
    : 'Upstairs Downstairs Podcast');
const description = frontmatter?.description || pageMeta?.description || '';
---

<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!--   <link rel="webmention" href="https://webmention.io/hellostu.xyz/webmention" />
  <link rel="pingback" href="https://webmention.io/hellostu.xyz/xmlrpc" /> -->
  <meta name="viewport" content="width=device-width" />
  <meta name="generator" content={Astro.generator} />
  <Fonts />
  <SEO
    title={title}
    description={description}
    openGraph={{
      basic: {
        title: title,
        type: frontmatter !== undefined ? 'article' : 'website',
        image: ogImage,
      },
      optional: {
        description: description,
      },
      article: { authors: ['Stuart Mackenzie'] },
    }}
    twitter={{
      creator: '@_disco',
      card: 'summary_large_image',
      title: title,
      image: ogImage,
      description: description,
    }}
  />
</head>
