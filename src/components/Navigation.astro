---
import '../styles/navigation.css';
import { readFile } from 'fs/promises';
import yaml from 'js-yaml';

let navLinks = [];
try {
  const navYaml = await readFile(
    new URL('../content/navigation.yaml', import.meta.url),
    'utf8',
  );
  navLinks = yaml.load(navYaml);
} catch (e) {
  console.error('Failed to load navigation.yaml', e);
}
---

<header id="top">
  <nav class="main-nav" role="navigation">
    <div class="brand">
      <h1 class="site-title"><a href="/">Upstairs / Downstairs</a></h1>
    </div>

    <div class="burger">
      <a
        role="button"
        class="burger-button"
        aria-label="hamburger button"
        aria-expanded="false"
        data-target="menu-links"
      >
        <svg width="50" height="50" viewBox="0 0 100 100">
          <path
            class="line line1"
            d="M 20,29.000046 H 80.000231 C 80.000231,29.000046 94.498839,28.817352 94.532987,66.711331 94.543142,77.980673 90.966081,81.670246 85.259173,81.668997 79.552261,81.667751 75.000211,74.999942 75.000211,74.999942 L 25.000021,25.000058"
          ></path>
          <path class="line line2" d="M 20,50 H 80"></path>
          <path
            class="line line3"
            d="M 20,70.999954 H 80.000231 C 80.000231,70.999954 94.498839,71.182648 94.532987,33.288669 94.543142,22.019327 90.966081,18.329754 85.259173,18.331003 79.552261,18.332249 75.000211,25.000058 75.000211,25.000058 L 25.000021,74.999942"
          ></path>
        </svg>
      </a>
    </div>

    <div
      id="menu-links"
      class="links-list"
      aria-expanded="false"
      aria-label="main menu"
    >
      <ul>
        {
          Array.isArray(navLinks) &&
            navLinks.map(
              link =>
                !link.label?.startsWith('#') && (
                  <li>
                    <a href={link.url}>{link.label}</a>
                  </li>
                ),
            )
        }
      </ul>
    </div>
  </nav>
  <!-- end nav -->
</header>
