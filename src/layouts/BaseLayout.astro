---
import HeadSEO from '../components/HeadSEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageScripts from '../components/PageScripts.astro';
import '../styles/global.css';
const { frontmatter, pageMeta, prevepisode, nextepisode } = Astro.props;
---

<html lang="en">
  <HeadSEO frontmatter={frontmatter} pageMeta={pageMeta} />
  <body>
    <div class="container">
      <Header />
      <main>
        <slot />
        <p class="toplink content-padding">
          <a href="#top">[Back to top]</a>
        </p>
      </main>
      <section class="episodeNav">
        {
          prevepisode && (
            <div class="prevNav">
              <a href={`/episodes/${prevepisode.slug}/`}>
                &lt&lt {prevepisode.data.title}
              </a>
            </div>
          )
        }
        {!nextepisode && prevepisode && <div class="nextNav"> (｡◕‿‿◕｡) </div>}
        {!prevepisode && nextepisode && <div class="prevNav"> (｡◕‿‿◕｡) </div>}
        {
          nextepisode && (
            <div class="nextNav">
              <a href={`/episodes/${nextepisode.slug}/`}>
                {nextepisode.data.title} &gt&gt
              </a>
            </div>
          )
        }
      </section>
      <Footer />
      <PageScripts />
    </div>
  </body>
</html>
