{
  "name": "updownpod-com",
  "type": "module",
  "version": "1.0.2",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "node src/scripts/fix-uploaded-image-paths.js",
    "build": "astro build && ts-node src/scripts/image-generation/generate-og-images.ts && ts-node src/scripts/image-generation/generate-preview-images.ts",
    "preview": "astro preview",
    "astro": "astro",
    "generate:og": "ts-node src/scripts/image-generation/generate-og-images.ts",
    "generate:preview": "ts-node src/scripts/image-generation/generate-preview-images.ts"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@sveltia/cms": "0.152.5",
    "astro": "^6.1.5",
    "astro-font": "1.1.0",
    "astro-icon": "1.1.5",
    "astro-imagetools": "0.9.0",
    "astro-seo": "1.1.0",
    "astro-social-share": "2.2.0",
    "firebase": "12.12.0",
    "firebase-admin": "13.8.0",
    "firebase-functions": "7.2.5",
    "gray-matter": "^4.0.3",
    "puppeteer": "^24.40.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss-preset-env": "^11.2.0",
    "ts-node": "^10.9.2"
  }
}
